# 极简配置：默认 HTTP 场景只需 feed 地址 + API Key（无鉴权可留空）
FEED_BASE_URL=http://localhost:4000
FEED_API_KEY=

# --- WebSearch（火山联网搜索，Phase1B 三条目优先）---
# 开通与 Key：https://console.volcengine.com/search-infinity/api-key
# 说明：docs/guides/data-source.md
WEB_SEARCH_PROVIDER=volc
WEB_SEARCH_API_KEY=
