# -----------------------------
# Minimal required
# -----------------------------
FEED_BASE_URL=http://localhost:4000
FEED_API_KEY=

# -----------------------------
# Optional feed advanced options
# -----------------------------
FEED_MCP_URL=http://localhost:4000/mcp

# -----------------------------
# Optional Phase0 defaults (CLI has higher priority)
# -----------------------------
PHASE0_REPORT_URL=
PHASE0_STOCK_CODE=
PHASE0_CATEGORY=年报
PHASE0_YEAR=
PHASE0_SAVE_DIR=./cache/reports
PHASE0_MAX_RETRIES=3
PHASE0_FORCE_REFRESH=false

# -----------------------------
# Optional workflow market pack (orchestrator synthetic §1 无风险利率)
# -----------------------------
PHASE1A_RF_RATE=
# 别名：MARKET_PACK_RF_RATE（与 PHASE1A_RF_RATE 二选一，代码优先读 PHASE1A_RF_RATE）

# -----------------------------
# Optional Phase1B demo defaults (CLI has higher priority)
# -----------------------------
PHASE1B_STOCK_CODE=
PHASE1B_COMPANY_NAME=
PHASE1B_YEAR=

# -----------------------------
# Optional Stage C agent sidecar (LangChain + ChatOpenAI, OpenAI-compatible)
# 不设 TS_LLM_API_KEY 则跳过 sidecar，不影响主 workflow。
# 完整说明见 docs/guides/agent-llm-and-env.md
# -----------------------------
# TS_LLM_PROVIDER=openai
# TS_LLM_MODEL=gpt-4o-mini
# TS_LLM_API_KEY=
# TS_LLM_BASE_URL=
# TS_LLM_PROXY_URL=
# TS_LLM_TEMPERATURE=0
# TS_LLM_TIMEOUT_MS=30000
#
# TS_LLM_PROVIDER 为 deepseek|doubao|qwen|glm|minimax|moonshot|gemini 时可省略 TS_LLM_BASE_URL（使用内置默认网关）。
# TS_LLM_PROVIDER=custom 时必须设置 TS_LLM_BASE_URL。
