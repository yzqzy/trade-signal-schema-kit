# -----------------------------
# Minimal required
# -----------------------------
FEED_BASE_URL=http://localhost:4000
FEED_API_KEY=

# -----------------------------
# Optional feed advanced options
# -----------------------------
FEED_MCP_URL=http://localhost:4000/mcp

# -----------------------------
# Optional Phase0 defaults (CLI has higher priority)
# -----------------------------
