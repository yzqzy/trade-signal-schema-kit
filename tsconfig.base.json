{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@trade-signal/schema-core": ["./packages/core-schema/src/index.ts"],
      "@trade-signal/provider-http": ["./packages/provider-http/src/index.ts"],
      "@trade-signal/provider-mcp": ["./packages/provider-mcp/src/index.ts"],
      "@trade-signal/research-strategies": [
        "./packages/research-strategies/src/index.ts"
      ],
      "@trade-signal/reporting": ["./packages/reporting/src/index.ts"]
    },
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
