{
  "name": "@trade-signal/research-strategies",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/packages/research-strategies/src/index.js",
  "types": "dist/packages/research-strategies/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/research-strategies/src/index.d.ts",
      "import": "./dist/packages/research-strategies/src/index.js",
      "default": "./dist/packages/research-strategies/src/index.js"
    }
  },
  "bin": {
    "ts-phase0-download": "dist/packages/research-strategies/src/cli/phase0-download.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "run:phase0-download": "node dist/packages/research-strategies/src/cli/phase0-download.js",
    "dev:phase1a-demo": "node dist/packages/research-strategies/src/stages/phase1a/demo.js",
    "dev:phase1b-demo": "node dist/packages/research-strategies/src/stages/phase1b/demo.js",
    "run:phase2a-extract": "node dist/packages/research-strategies/src/cli/phase2a-extract.js",
    "run:phase2b-render": "node dist/packages/research-strategies/src/cli/phase2b-render.js",
    "run:phase3": "node dist/packages/research-strategies/src/cli/phase3-run.js",
    "run:valuation": "node dist/packages/research-strategies/src/cli/valuation.js",
    "run:report-to-html": "node dist/packages/research-strategies/src/cli/report-to-html.js",
    "run:workflow": "node dist/packages/research-strategies/src/cli/workflow.js",
    "run:business-analysis": "node dist/packages/research-strategies/src/cli/business-analysis.js",
    "run:screener": "node dist/packages/research-strategies/src/screener/cli.js",
    "quality:phase3-golden": "node dist/packages/research-strategies/src/quality/phase3-golden-check.js --suite all",
    "quality:strategy-registry": "node dist/packages/research-strategies/src/quality/strategy-plugin-smoke.js",
    "quality:conformance": "pnpm --filter @trade-signal/provider-http run build && pnpm --filter @trade-signal/provider-mcp run build && node dist/packages/research-strategies/src/quality/conformance-check.js",
    "quality:contract": "node dist/packages/research-strategies/src/quality/contract-check.js",
    "quality:regression": "node dist/packages/research-strategies/src/quality/regression-check.js --suite all",
    "quality:all": "pnpm run quality:conformance && pnpm run quality:contract && pnpm run quality:regression && pnpm run quality:phase3-golden && pnpm run quality:strategy-registry",
    "gen:phase3-golden": "node dist/packages/research-strategies/src/quality/generate-phase3-golden-fixtures.js",
    "test:linkage": "node dist/packages/research-strategies/src/tests/linkage-smoke.js",
    "test:phase1b-quality": "node dist/packages/research-strategies/src/tests/phase1b-evidence-quality-smoke.js",
    "test:phase1a-strict": "node dist/packages/research-strategies/src/tests/phase1a-strict-preflight-smoke.js",
    "test:phase2": "node dist/packages/research-strategies/src/tests/phase2a-logic-smoke.js",
    "test:screener": "node dist/packages/research-strategies/src/tests/screener-smoke.js"
  },
  "dependencies": {
    "@langchain/langgraph": "0.2.74",
    "@trade-signal/provider-http": "workspace:*",
    "@trade-signal/provider-mcp": "workspace:*",
    "@trade-signal/reporting": "workspace:*",
    "@trade-signal/schema-core": "workspace:*",
    "dotenv": "^17.2.3",
    "file-type": "^22.0.1",
    "got": "^15.0.1",
    "p-retry": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "undici": "^7.12.0"
  }
}
