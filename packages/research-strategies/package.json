{
  "name": "@trade-signal/research-strategies",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ts-phase0-download": "dist/packages/research-strategies/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "phase0:download": "node dist/packages/research-strategies/src/cli.js",
    "phase1a:demo": "node dist/packages/research-strategies/src/phase1a/demo.js",
    "phase1b:demo": "node dist/packages/research-strategies/src/phase1b/demo.js",
    "phase2a:extract": "node dist/packages/research-strategies/src/phase2a/cli.js",
    "phase2b:render": "node dist/packages/research-strategies/src/phase2b/cli.js",
    "phase3:run": "node dist/packages/research-strategies/src/phase3/cli.js",
    "valuation:run": "node dist/packages/research-strategies/src/valuation/cli.js",
    "report-to-html:run": "node dist/packages/research-strategies/src/report-to-html/cli.js",
    "workflow:run": "node dist/packages/research-strategies/src/workflow/cli.js",
    "business-analysis:run": "node dist/packages/research-strategies/src/business-analysis/cli.js",
    "screener:run": "node dist/packages/research-strategies/src/screener/cli.js",
    "quality:phase3-golden": "node dist/packages/research-strategies/src/quality/phase3-golden-check.js --suite all",
    "quality:conformance": "pnpm --filter @trade-signal/provider-http run build && pnpm --filter @trade-signal/provider-mcp run build && node dist/packages/research-strategies/src/quality/conformance-check.js",
    "quality:contract": "node dist/packages/research-strategies/src/quality/contract-check.js",
    "quality:regression": "node dist/packages/research-strategies/src/quality/regression-check.js --suite all",
    "quality:all": "pnpm run quality:conformance && pnpm run quality:contract && pnpm run quality:regression && pnpm run quality:phase3-golden",
    "test:linkage": "node dist/packages/research-strategies/src/tests/linkage-smoke.js",
    "test:phase2": "node dist/packages/research-strategies/src/tests/phase2a-logic-smoke.js"
  },
  "dependencies": {
    "@trade-signal/provider-http": "workspace:*",
    "@trade-signal/provider-mcp": "workspace:*",
    "@trade-signal/schema-core": "workspace:*",
    "dotenv": "^17.2.3",
    "file-type": "^22.0.1",
    "got": "^15.0.1",
    "p-retry": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "@trade-signal/reporting": "workspace:*"
  }
}
