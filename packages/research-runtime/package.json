{
  "name": "@trade-signal/research-runtime",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/packages/research-runtime/src/index.js",
  "types": "dist/packages/research-runtime/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/research-runtime/src/index.d.ts",
      "import": "./dist/packages/research-runtime/src/index.js",
      "default": "./dist/packages/research-runtime/src/index.js"
    }
  },
  "bin": {
    "ts-phase0-download": "dist/packages/research-runtime/src/cli/phase0-download.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "run:phase0-download": "node dist/packages/research-runtime/src/cli/phase0-download.js",
    "dev:phase1a-demo": "node dist/packages/research-runtime/src/steps/phase1a/demo.js",
    "dev:phase1b-demo": "node dist/packages/research-runtime/src/steps/phase1b/demo.js",
    "run:phase2a-extract": "node dist/packages/research-runtime/src/cli/phase2a-extract.js",
    "run:phase2b-render": "node dist/packages/research-runtime/src/cli/phase2b-render.js",
    "run:phase3": "node dist/packages/research-runtime/src/cli/phase3-run.js",
    "run:valuation": "node dist/packages/research-runtime/src/cli/valuation.js",
    "run:evidence-index-normalize": "node dist/packages/research-runtime/src/cli/evidence-index-normalize.js",
    "run:workflow": "node dist/packages/research-runtime/src/cli/workflow.js",
    "run:business-analysis": "node dist/packages/research-runtime/src/cli/business-analysis.js",
    "run:reports-site-emit": "node dist/packages/research-runtime/src/cli/reports-site-emit.js",
    "run:reports-site-sync": "node dist/packages/research-runtime/src/cli/reports-site-sync.js",
    "run:reports-site-clear": "node dist/packages/research-runtime/src/cli/reports-site-clear.js",
    "run:websearch-smoke": "node dist/packages/research-runtime/src/cli/websearch-smoke.js",
    "run:screener": "node dist/packages/research-runtime/src/screener/cli.js",
    "quality:phase3-golden": "node dist/packages/research-runtime/src/quality/phase3-golden-check.js --suite all",
    "quality:strategy-registry": "node dist/packages/research-runtime/src/quality/strategy-plugin-smoke.js",
    "quality:conformance": "pnpm --filter @trade-signal/provider-http run build && node dist/packages/research-runtime/src/quality/conformance-check.js",
    "quality:contract": "node dist/packages/research-runtime/src/quality/contract-check.js",
    "quality:p1-fields": "node dist/packages/research-runtime/src/quality/p1-field-gate-check.js",
    "quality:p2-lite": "node dist/packages/research-runtime/src/quality/p2-lite-gate-check.js",
    "quality:regression": "node dist/packages/research-runtime/src/quality/regression-check.js --suite all",
    "quality:all": "pnpm run quality:conformance && pnpm run quality:contract && pnpm run quality:p1-fields && pnpm run quality:p2-lite && pnpm run quality:regression && pnpm run quality:phase3-golden && pnpm run quality:strategy-registry",
    "gen:phase3-golden": "node dist/packages/research-runtime/src/quality/generate-phase3-golden-fixtures.js",
    "test:linkage": "node dist/packages/research-runtime/src/tests/linkage-smoke.js && node dist/packages/research-runtime/src/tests/v2-layer-import-guard.js && node dist/packages/research-runtime/src/tests/workspace-layer-guard.js",
    "test:v2-layer-guard": "node dist/packages/research-runtime/src/tests/v2-layer-import-guard.js",
    "test:workspace-layer-guard": "node dist/packages/research-runtime/src/tests/workspace-layer-guard.js",
    "test:phase1b-quality": "node dist/packages/research-runtime/src/tests/phase1b-evidence-quality-smoke.js",
    "test:phase1a-strict": "node dist/packages/research-runtime/src/tests/phase1a-strict-preflight-smoke.js",
    "test:phase2": "node dist/packages/research-runtime/src/tests/phase2a-logic-smoke.js",
    "test:screener": "node dist/packages/research-runtime/src/tests/screener-smoke.js"
  },
  "dependencies": {
    "@trade-signal/provider-http": "workspace:*",
    "@trade-signal/research-contracts": "workspace:*",
    "@trade-signal/research-feature": "workspace:*",
    "@trade-signal/research-policy": "workspace:*",
    "@trade-signal/research-selection": "workspace:*",
    "@trade-signal/research-topic": "workspace:*",
    "@trade-signal/schema-core": "workspace:*",
    "dotenv": "^17.2.3",
    "file-type": "^22.0.1",
    "got": "^15.0.1",
    "p-retry": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^4.10.38",
    "undici": "^7.12.0"
  }
}
