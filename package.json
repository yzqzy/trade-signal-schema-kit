{
  "name": "trade-signal-schema-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Schema-first market data toolkit",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "phase0:download": "pnpm --filter @trade-signal/research-strategies run phase0:download",
    "workflow:run": "pnpm --filter @trade-signal/research-strategies run workflow:run",
    "business-analysis:run": "pnpm --filter @trade-signal/research-strategies run business-analysis:run",
    "quality:conformance": "pnpm --filter @trade-signal/research-strategies run quality:conformance",
    "quality:contract": "pnpm --filter @trade-signal/research-strategies run quality:contract",
    "quality:regression": "pnpm --filter @trade-signal/research-strategies run quality:regression",
    "quality:phase3-golden": "pnpm --filter @trade-signal/research-strategies run quality:phase3-golden",
    "quality:all": "pnpm --filter @trade-signal/research-strategies run quality:all",
    "screener:run": "pnpm --filter @trade-signal/research-strategies run screener:run",
    "web:dev": "pnpm --filter @trade-signal/screener-web run dev"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
