{
  "name": "trade-signal-schema-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Schema-first market data toolkit",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "pnpm run build",
    "typecheck": "pnpm -r run typecheck",
    "phase0:download": "pnpm --filter @trade-signal/research-strategies run run:phase0-download",
    "workflow:run": "pnpm --filter @trade-signal/research-strategies run run:workflow",
    "business-analysis:run": "pnpm --filter @trade-signal/research-strategies run run:business-analysis",
    "valuation:run": "pnpm --filter @trade-signal/research-strategies run run:valuation",
    "report-to-html:run": "pnpm --filter @trade-signal/research-strategies run run:report-to-html",
    "quality:conformance": "pnpm --filter @trade-signal/research-strategies run quality:conformance",
    "quality:contract": "pnpm --filter @trade-signal/research-strategies run quality:contract",
    "quality:regression": "pnpm --filter @trade-signal/research-strategies run quality:regression",
    "quality:phase3-golden": "pnpm --filter @trade-signal/research-strategies run quality:phase3-golden",
    "quality:all": "pnpm --filter @trade-signal/research-strategies run quality:all",
    "test:linkage": "pnpm run build && pnpm --filter @trade-signal/research-strategies run test:linkage",
    "test:screener": "pnpm run build && pnpm --filter @trade-signal/research-strategies run test:screener",
    "screener:run": "pnpm --filter @trade-signal/research-strategies run run:screener"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
